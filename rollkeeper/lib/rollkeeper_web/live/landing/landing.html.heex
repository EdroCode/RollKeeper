        </p>
      </div>
    </div>
    <div class="flex flex-col border-none border-white rounded-2xl p-4 gap-4">
      <h1 class="text-3xl text-white font-bold ">Features</h1>
      <div class="flex flex-col gap-4 py-4 w-full">
        <.card title="Dice Roller" description="Roll your dices, virtually!" />
        <.card title="Dice Roller" description="Roll your dices, virtually!" />
        <.card title="Dice Roller" description="Roll your dices, virtually!" />
      </div>
    </div>
