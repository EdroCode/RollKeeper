      <.d20 class="text-black bg-white rounded-2xl p-2 w-16" />
      <div class="flex flex-col ">
        <h1 class="text-4xl text-white group-hover:text-black font-bold ">RollKeeper</h1>
        <h3 class="text-white font-medium group-hover:text-black">
          A dashboard for any RPG session
        </h3>
      </div>
    </a>
    <div class="flex flex-col border-none border-white rounded-2xl p-4 gap-4">
